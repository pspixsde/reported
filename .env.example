# Upstash Redis (Vercel KV) — required for production, optional for local dev.
# When missing, the app falls back to local file-based storage.
# Get these from: Vercel Dashboard > Storage > your KV database
KV_REST_API_URL=https://your-database.upstash.io
KV_REST_API_TOKEN=your-token-here

# Optional: Bing Webmaster Tools site verification code
# Used as <meta name="msvalidate.01" content="...">
NEXT_PUBLIC_BING_VERIFICATION=your-bing-verification-code
